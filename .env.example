# ===== GitHub OAuth =====
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost/api/oauth/github/callback

# ===== 加密密钥（独立用途，请用 openssl rand -base64 32 生成）=====
ENCRYPTION_KEY=
SESSION_SECRET=

# ===== 数据库 =====
DB_PASSWORD=agentpod-dev-password
DATABASE_URL=postgresql+asyncpg://agentpod:agentpod-dev-password@postgres:5432/agentpod

# ===== Docker =====
DOCKER_HOST=tcp://docker-proxy:2375
AGENT_IMAGE=agentpod-agent:latest
ENABLE_TERMINAL=0
TERMINAL_WHITELIST=python,python3,pip,pip3,pytest,uv

# ===== Embedding 服务（TEI）=====
# Apple Silicon / aarch64: cpu-arm64-latest；Linux x86_64: cpu-1.9 或 cpu-latest
TEI_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-1.9
EMBEDDING_BASE_URL=http://tei:80
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 聊天附件大小上限（字节），默认 1MB
ATTACHMENT_MAX_BYTES=1048576
ATTACHMENT_STORAGE=minio
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=agentpod
S3_SECRET_KEY=agentpodsecret
S3_BUCKET=agentpod-attachments
S3_REGION=us-east-1
S3_USE_SSL=0
AGENT_INTERNAL_NETWORK=agentpod-internal

# ===== 容器资源限制 =====
AGENT_MEMORY_LIMIT=128m
AGENT_CPU_QUOTA=50000
AGENT_PIDS_LIMIT=256
# 每用户 /data 卷磁盘配额（如 2g）。空=不限。
# 仅当宿主 docker 卷所在 FS 支持 project quota（XFS pquota / ext4 project）时生效，否则建卷会报错。
AGENT_DISK_LIMIT=

# ===== 生命周期（秒）：24h 空闲才 pause，pause 后 7 天才 stop =====
IDLE_PAUSE_SECONDS=86400
PAUSE_TO_STOP_SECONDS=604800

# ===== 公开地址 =====
PUBLIC_BASE_URL=http://localhost

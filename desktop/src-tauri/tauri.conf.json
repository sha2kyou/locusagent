{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentPod",
  "version": "0.1.2",
  "identifier": "com.agentpod.desktop",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run build:desktop",
    "beforeBuildCommand": "cd ../frontend && npm run build:desktop",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../frontend/dist-desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": {
      "../../frontend/dist-desktop/": "dist-desktop/",
      "resources/sidecar-venv/": "sidecar-venv/",
      "resources/shared-skills/": "shared-skills/"
    }
  }
}

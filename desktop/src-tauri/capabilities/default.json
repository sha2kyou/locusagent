{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default AgentPod desktop capability",
  "windows": ["main", "quick-chat"],
  "remote": {
    "urls": ["http://127.0.0.1:21223", "http://127.0.0.1:21223/*"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "window-state:default",
    "notification:default",
    "autostart:default",
    "allow-desktop-get-prefs",
    "allow-desktop-get-system-locale",
    "allow-desktop-set-prefs",
    "allow-desktop-apply-devtools-settings",
    "allow-desktop-open-session-in-main",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered"
  ]
}

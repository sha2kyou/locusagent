{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default AgentPod desktop capability",
  "windows": ["main"],
  "remote": {
    "urls": ["http://127.0.0.1:21223", "http://127.0.0.1:21223/*"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "window-state:default",
    "notification:default",
    "autostart:default"
  ]
}

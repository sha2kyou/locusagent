{
	auto_https off
}

:80 {
	# 仅压缩静态/JSON 类型，显式排除 text/event-stream，避免破坏 SSE 流式对话
	encode {
		zstd
		gzip
		match {
			header Content-Type text/html*
			header Content-Type text/css*
			header Content-Type application/javascript*
			header Content-Type text/javascript*
			header Content-Type application/json*
			header Content-Type image/svg+xml*
		}
	}

	# Agent 内部代理仅 Docker 内网可达；公网禁止（与 Host internal_network 中间件双保险）
	@internal_agent path /internal/llm* /internal/tavily* /internal/jina* /internal/embedding* /internal/attachments* /internal/notifications* /internal/scheduled-tasks* /internal/settings* /internal/usage*
	handle @internal_agent {
		respond "Forbidden" 403
	}

	@api path /api/* /health
	handle @api {
		reverse_proxy host:8080 {
			flush_interval -1
			transport http {
				read_buffer 0
				write_buffer 0
				# Docker 内嵌 DNS；dial_timeout 避免 host 重建后连旧 IP 长时间挂起
				resolvers 127.0.0.11:53
				dial_timeout 5s
				response_header_timeout 120s
			}
		}
	}

	handle {
		reverse_proxy web:80 {
			transport http {
				resolvers 127.0.0.11:53
				dial_timeout 5s
			}
		}
	}
}
